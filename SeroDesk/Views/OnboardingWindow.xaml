<Window x:Class="SeroDesk.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to SeroDesk"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <!-- Dark backdrop -->
        <Border Background="#F0000000"/>

        <!-- Content Card -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CornerRadius="28"
                MaxWidth="640"
                MinHeight="480"
                Padding="48,40">
            <Border.Background>
                <SolidColorBrush Color="#1C1C1E" Opacity="0.98"/>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="60" Opacity="0.6" ShadowDepth="12"/>
            </Border.Effect>

            <!-- Pages Container -->
            <Grid x:Name="PagesContainer">
                <!-- Page 1: Welcome -->
                <StackPanel x:Name="Page1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- App Logo -->
                    <Border Width="100" Height="100"
                            CornerRadius="24"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,32">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#007AFF" Offset="0"/>
                                <GradientStop Color="#5856D6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="S" Foreground="White"
                                  FontSize="48" FontWeight="Light"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Welcome to SeroDesk"
                              Foreground="White"
                              FontSize="32" FontWeight="SemiBold"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,12"/>

                    <TextBlock Text="A modern touch-optimized shell for Windows."
                              Foreground="#AAFFFFFF"
                              FontSize="16"
                              HorizontalAlignment="Center"
                              TextAlignment="Center"
                              MaxWidth="400"
                              Margin="0,0,0,48"/>

                    <Button Content="Get Started"
                            Click="NextPage_Click"
                            Cursor="Hand"
                            HorizontalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#007AFF"
                                        CornerRadius="16"
                                        Padding="40,14">
                                    <TextBlock Text="{TemplateBinding Content}"
                                              Foreground="White"
                                              FontSize="17"
                                              FontWeight="SemiBold"
                                              HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Page 2: Features -->
                <StackPanel x:Name="Page2" Visibility="Collapsed"
                           VerticalAlignment="Center">
                    <TextBlock Text="How it works"
                              Foreground="White"
                              FontSize="28" FontWeight="SemiBold"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,32"/>

                    <!-- Feature list -->
                    <StackPanel HorizontalAlignment="Center" MaxWidth="420">
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="👆" FontSize="24" VerticalAlignment="Top" Margin="0,2,0,0"/>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Long-press to rearrange" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Hold an app icon to enter edit mode. Drag icons to reorder or create folders." Foreground="#99FFFFFF" FontSize="13" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="👈" FontSize="24" VerticalAlignment="Top" Margin="0,2,0,0"/>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Swipe between pages" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Swipe left or right to navigate between app pages. Drag to the edge to create new pages." Foreground="#99FFFFFF" FontSize="13" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⌨️" FontSize="24" VerticalAlignment="Top" Margin="0,2,0,0"/>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Keyboard shortcuts" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Win key = Home  |  Win+Tab = App Switcher  |  Win+D = Desktop  |  Shift+Esc = Exit" Foreground="#99FFFFFF" FontSize="13" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⬇️" FontSize="24" VerticalAlignment="Top" Margin="0,2,0,0"/>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Pull-down menus" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Swipe down from top-left for notifications, top-right for Control Center." Foreground="#99FFFFFF" FontSize="13" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <Button Content="Start using SeroDesk"
                            Click="Finish_Click"
                            Cursor="Hand"
                            HorizontalAlignment="Center"
                            Margin="0,24,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#007AFF"
                                        CornerRadius="16"
                                        Padding="40,14">
                                    <TextBlock Text="{TemplateBinding Content}"
                                              Foreground="White"
                                              FontSize="17"
                                              FontWeight="SemiBold"
                                              HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Page Indicator Dots -->
        <StackPanel Orientation="Horizontal"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,60">
            <Ellipse x:Name="Dot1" Width="8" Height="8" Fill="White" Margin="4"/>
            <Ellipse x:Name="Dot2" Width="8" Height="8" Fill="#50FFFFFF" Margin="4"/>
        </StackPanel>
    </Grid>
</Window>
