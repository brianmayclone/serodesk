<UserControl x:Class="SeroDesk.Views.SeroControlCenter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="480">

    <!-- iOS 17-Style Control Center -->
    <Grid x:Name="ControlPanel"
          Visibility="Collapsed"
          RenderTransformOrigin="0.5,0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="ControlTransform" Y="-1080"/>
        </Grid.RenderTransform>

        <!-- Blurred dark backdrop -->
        <Border Background="#E8000000" CornerRadius="0,0,32,0"/>

        <!-- Content -->
        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                     HorizontalScrollBarVisibility="Disabled"
                     Margin="20,52,20,100">
            <StackPanel>

                <!-- Grab Handle -->
                <Border Background="#50FFFFFF"
                       CornerRadius="2.5"
                       Width="36" Height="5"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

                <!-- Connectivity Card -->
                <Border CornerRadius="20"
                       Margin="0,0,0,12"
                       Padding="16">
                    <Border.Background>
                        <SolidColorBrush Color="#2C2C2E" Opacity="0.95"/>
                    </Border.Background>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 1: WiFi, Bluetooth -->
                        <UniformGrid Grid.Row="0" Columns="2" Margin="0,0,0,8">
                            <!-- WiFi Toggle -->
                            <Button x:Name="WiFiToggle" Background="#FF007AFF"
                                   BorderThickness="0" Height="72" Margin="0,0,4,0"
                                   Click="WiFiToggle_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                               CornerRadius="14">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="M1,9l2,2c4.97-4.97,13.03-4.97,18,0l2-2C16.93,2.93,7.08,2.93,1,9z M9,17l3,3l3-3 c-1.65-1.66-4.34-1.66-6,0z M5,13l2,2c2.76-2.76,7.24-2.76,10,0l2-2C15.14,9.14,8.87,9.14,5,13z"
                                                     Fill="White" Stretch="Uniform"
                                                     Width="26" Height="26" Margin="0,0,0,6"/>
                                                <TextBlock Text="Wi-Fi" Foreground="White"
                                                          FontSize="11" FontWeight="SemiBold"
                                                          HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Bluetooth Toggle -->
                            <Button x:Name="BluetoothToggle" Background="#FF3A3A3C"
                                   BorderThickness="0" Height="72" Margin="4,0,0,0"
                                   Click="BluetoothToggle_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                               CornerRadius="14">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="M17,7l-4-4v3.5L9.5,3L8,4.5l4.5,4.5L8,13.5L9.5,15L13,11.5V15l4-4l-2.8-2.8L17,7z M13,4.6l1.7,1.7L13,8V4.6z M14.7,11.7L13,13.4v-3.5L14.7,11.7z"
                                                     Fill="White" Stretch="Uniform"
                                                     Width="24" Height="24" Margin="0,0,0,6"/>
                                                <TextBlock Text="Bluetooth" Foreground="White"
                                                          FontSize="11" FontWeight="SemiBold"
                                                          HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </UniformGrid>

                        <!-- Row 2: Airplane, Hotspot -->
                        <UniformGrid Grid.Row="1" Columns="2">
                            <!-- Airplane Mode Toggle -->
                            <Button x:Name="AirplaneModeToggle" Background="#FF3A3A3C"
                                   BorderThickness="0" Height="72" Margin="0,0,4,0"
                                   Click="AirplaneModeToggle_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                               CornerRadius="14">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="M21,16v-2l-8-5V3.5C13,2.67,12.33,2,11.5,2S10,2.67,10,3.5V9l-8,5v2l8-2.5V19l-2,1.5V22l3.5-1l3.5,1v-1.5L13,19v-5.5L21,16z"
                                                     Fill="White" Stretch="Uniform"
                                                     Width="24" Height="24" Margin="0,0,0,6"/>
                                                <TextBlock Text="Airplane" Foreground="White"
                                                          FontSize="11" FontWeight="SemiBold"
                                                          HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Hotspot Toggle -->
                            <Button x:Name="HotspotToggle" Background="#FF3A3A3C"
                                   BorderThickness="0" Height="72" Margin="4,0,0,0"
                                   Click="HotspotToggle_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                               CornerRadius="14">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="M12,11c-1.1,0-2,0.9-2,2s0.9,2,2,2s2-0.9,2-2S13.1,11,12,11z M18,13c0-3.31-2.69-6-6-6s-6,2.69-6,6 c0,2.22,1.21,4.15,3,5.19l1-1.74c-1.19-0.7-2-1.97-2-3.45c0-2.21,1.79-4,4-4s4,1.79,4,4c0,1.48-0.81,2.75-2,3.45l1,1.74 C16.79,17.15,18,15.22,18,13z M12,3C6.48,3,2,7.48,2,13c0,3.7,2.01,6.92,4.99,8.65l1-1.73C5.61,18.53,4,15.96,4,13 c0-4.42,3.58-8,8-8s8,3.58,8,8c0,2.96-1.61,5.53-4,6.92l1,1.73c2.99-1.73,5-4.95,5-8.65C22,7.48,17.52,3,12,3z"
                                                     Fill="White" Stretch="Uniform"
                                                     Width="24" Height="24" Margin="0,0,0,6"/>
                                                <TextBlock Text="Hotspot" Foreground="White"
                                                          FontSize="11" FontWeight="SemiBold"
                                                          HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </UniformGrid>
                    </Grid>
                </Border>

                <!-- Brightness Card -->
                <Border CornerRadius="20"
                       Margin="0,0,0,12"
                       Padding="20,16">
                    <Border.Background>
                        <SolidColorBrush Color="#2C2C2E" Opacity="0.95"/>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="BRIGHTNESS" Foreground="#8E8E93"
                                  FontSize="11" FontWeight="SemiBold"
                                  Margin="0,0,0,12"
/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Sun icon small -->
                            <Path Grid.Column="0"
                                 Data="M12,9c1.65,0,3,1.35,3,3s-1.35,3-3,3s-3-1.35-3-3S10.35,9,12,9 M12,7c-2.76,0-5,2.24-5,5s2.24,5,5,5s5-2.24,5-5 S14.76,7,12,7L12,7z M2,13l2,0l0-2l-2,0L2,13z M20,13l2,0l0-2l-2,0L20,13z M11,2l0,2l2,0l0-2L11,2z M11,20l0,2l2,0l0-2L11,20z M5.99,4.58l-1.41,1.41l1.41,1.41l1.41-1.41L5.99,4.58z M18.01,16.59l-1.41,1.41l1.41,1.41l1.41-1.41L18.01,16.59z M5.99,19.41 l1.41-1.41l-1.41-1.41l-1.41,1.41L5.99,19.41z M18.01,7.41l1.41-1.41l-1.41-1.41l-1.41,1.41L18.01,7.41z"
                                 Fill="#AAFFFFFF" Stretch="Uniform"
                                 Width="18" Height="18"
                                 Margin="0,0,14,0" VerticalAlignment="Center"/>

                            <!-- Brightness Slider -->
                            <Slider Grid.Column="1"
                                   x:Name="BrightnessSlider"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding BrightnessLevel, Mode=TwoWay}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource TouchSliderStyle}"
                                   ValueChanged="BrightnessSlider_ValueChanged"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Volume Card -->
                <Border CornerRadius="20"
                       Margin="0,0,0,12"
                       Padding="20,16">
                    <Border.Background>
                        <SolidColorBrush Color="#2C2C2E" Opacity="0.95"/>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="VOLUME" Foreground="#8E8E93"
                                  FontSize="11" FontWeight="SemiBold"
                                  Margin="0,0,0,12"
/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Speaker icon -->
                            <Path Grid.Column="0"
                                 Data="M3,9v6h4l5,5V4L7,9H3z M16.5,12c0-1.77-1.02-3.29-2.5-4.03v8.05C15.48,15.29,16.5,13.77,16.5,12z M14,3.23v2.06 c2.89,0.86,5,3.54,5,6.71s-2.11,5.85-5,6.71v2.06c4.01-0.91,7-4.49,7-8.77S18.01,4.14,14,3.23z"
                                 Fill="#AAFFFFFF" Stretch="Uniform"
                                 Width="18" Height="18"
                                 Margin="0,0,14,0" VerticalAlignment="Center"/>

                            <!-- Volume Slider -->
                            <Slider Grid.Column="1"
                                   x:Name="VolumeSlider"
                                   Minimum="0" Maximum="100"
                                   Value="{Binding VolumeLevel, Mode=TwoWay}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource TouchSliderStyle}"
                                   ValueChanged="VolumeSlider_ValueChanged"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Screen Lock / Rotation -->
                <Border CornerRadius="20"
                       Margin="0,0,0,12"
                       Padding="16">
                    <Border.Background>
                        <SolidColorBrush Color="#2C2C2E" Opacity="0.95"/>
                    </Border.Background>
                    <Button x:Name="OrientationLockToggle" Background="Transparent"
                           BorderThickness="0" Height="56"
                           HorizontalContentAlignment="Stretch"
                           Click="OrientationLockToggle_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Lock icon -->
                                    <Border Grid.Column="0" Background="#FF3A3A3C"
                                           CornerRadius="12" Width="44" Height="44"
                                           Margin="0,0,14,0">
                                        <Path Data="M18,8h-1V6c0-2.76-2.24-5-5-5S7,3.24,7,6v2H6c-1.1,0-2,0.9-2,2v10c0,1.1,0.9,2,2,2h12c1.1,0,2-0.9,2-2V10 C20,8.9,19.1,8,18,8z M12,17c-1.1,0-2-0.9-2-2s0.9-2,2-2s2,0.9,2,2S13.1,17,12,17z M15.1,8H8.9V6c0-1.71,1.39-3.1,3.1-3.1 s3.1,1.39,3.1,3.1V8z"
                                             Fill="White" Stretch="Uniform"
                                             Width="22" Height="22"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Screen Lock"
                                                  Foreground="White" FontSize="15"/>
                                        <TextBlock x:Name="OrientationLockStatus"
                                                  Text="Off" Foreground="#8E8E93"
                                                  FontSize="13"/>
                                    </StackPanel>
                                </Grid>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Home Indicator -->
        <Border Background="#50FFFFFF"
               CornerRadius="2.5"
               Width="134" Height="5"
               VerticalAlignment="Bottom"
               HorizontalAlignment="Center"
               Margin="0,0,0,12"/>
    </Grid>
</UserControl>
