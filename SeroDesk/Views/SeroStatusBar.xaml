<UserControl x:Class="SeroDesk.Views.SeroStatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Height="36"
             d:DesignWidth="1920">

    <Border x:Name="StatusBarBackground"
            Background="#00000000"
            BorderThickness="0">
        <Grid Margin="24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Signal bars + Network -->
            <StackPanel Grid.Column="0"
                       Orientation="Horizontal"
                       VerticalAlignment="Center">

                <!-- Signal Strength Bars (use Fill binding with converter) -->
                <StackPanel Orientation="Horizontal"
                           VerticalAlignment="Bottom"
                           Margin="0,0,6,0"
                           Height="16">
                    <Border Width="3" Height="4" CornerRadius="1" Margin="0,0,1.5,0"
                            VerticalAlignment="Bottom"
                            Background="{Binding SignalStrength, Converter={StaticResource SignalToBrushConverter}, ConverterParameter=1}"/>
                    <Border Width="3" Height="7" CornerRadius="1" Margin="0,0,1.5,0"
                            VerticalAlignment="Bottom"
                            Background="{Binding SignalStrength, Converter={StaticResource SignalToBrushConverter}, ConverterParameter=2}"/>
                    <Border Width="3" Height="10" CornerRadius="1" Margin="0,0,1.5,0"
                            VerticalAlignment="Bottom"
                            Background="{Binding SignalStrength, Converter={StaticResource SignalToBrushConverter}, ConverterParameter=3}"/>
                    <Border Width="3" Height="13" CornerRadius="1"
                            VerticalAlignment="Bottom"
                            Background="{Binding SignalStrength, Converter={StaticResource SignalToBrushConverter}, ConverterParameter=4}"/>
                </StackPanel>

                <TextBlock Text="{Binding NetworkStatus}"
                          Foreground="White"
                          FontSize="13"
                          FontWeight="SemiBold"
                          VerticalAlignment="Center"
                          Opacity="0.95"/>
            </StackPanel>

            <!-- Center: Time -->
            <TextBlock Grid.Column="1"
                      Text="{Binding CurrentTime}"
                      Foreground="White"
                      FontSize="15"
                      FontWeight="Bold"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="0.5" Opacity="0.4"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- Right: Exit + Battery -->
            <StackPanel Grid.Column="2"
                       Orientation="Horizontal"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center">

                <!-- Debug Exit Button -->
                <Border Background="#E0FF3B30"
                        CornerRadius="4"
                        Padding="6,2"
                        Margin="0,0,10,0"
                        Cursor="Hand">
                    <Button x:Name="DebugExitButton"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="DebugExitButton_Click"
                            ToolTip="Exit SeroDesk (Shift+Esc)">
                        <TextBlock Text="EXIT"
                                   Foreground="White"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </Button>
                </Border>

                <!-- Battery Percentage -->
                <TextBlock Text="{Binding BatteryPercentage, StringFormat={}{0}%}"
                          Foreground="White"
                          FontSize="13"
                          FontWeight="SemiBold"
                          VerticalAlignment="Center"
                          Margin="0,0,5,0"
                          Opacity="0.95"/>

                <!-- Battery Icon -->
                <Grid Width="25" Height="12" VerticalAlignment="Center">
                    <Border Background="Transparent"
                           BorderBrush="White"
                           BorderThickness="1.2"
                           CornerRadius="2.5"
                           Width="22" Height="11"
                           HorizontalAlignment="Left"
                           Opacity="0.9"/>
                    <Border Background="White"
                           Width="1.5" Height="5"
                           HorizontalAlignment="Right"
                           CornerRadius="0,1,1,0"
                           Opacity="0.5"/>
                    <Border Background="{Binding BatteryPercentage, Converter={StaticResource BatteryToBrushConverter}}"
                           Width="{Binding BatteryPercentage, Converter={StaticResource BatteryToWidthConverter}}"
                           Height="7"
                           HorizontalAlignment="Left"
                           Margin="2,0,0,0"
                           CornerRadius="1.5"/>
                    <Path Data="M11.67,3.5L9.17,8.5H11L9.33,12.5L12.83,7.5H11L11.67,3.5Z"
                          Fill="White" Stretch="Uniform"
                          Width="7" Height="7"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Visibility="{Binding IsCharging, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
