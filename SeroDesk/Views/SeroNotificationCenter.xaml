<UserControl x:Class="SeroDesk.Views.SeroNotificationCenter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="480">

    <!-- iOS 17-Style Notification Center -->
    <Grid x:Name="NotificationPanel"
          Visibility="Collapsed"
          RenderTransformOrigin="0.5,0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="NotificationTransform" Y="-1080"/>
        </Grid.RenderTransform>

        <!-- Dark backdrop -->
        <Border Background="#E8000000" CornerRadius="0,0,0,32"/>

        <!-- Content -->
        <Grid Margin="20,52,20,100">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Grab Handle -->
            <Border Grid.Row="0"
                   Background="#50FFFFFF"
                   CornerRadius="2.5"
                   Width="36" Height="5"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

            <!-- Date + Time Header -->
            <StackPanel Grid.Row="1" Margin="8,0,0,16">
                <TextBlock x:Name="DateText"
                          Foreground="#88FFFFFF"
                          FontSize="15"
                          FontWeight="SemiBold"/>
                <TextBlock x:Name="TimeText"
                          Foreground="White"
                          FontSize="48"
                          FontWeight="Light"
                          Margin="0,-6,0,0"/>
            </StackPanel>

            <!-- Header Row -->
            <Grid Grid.Row="2" Margin="8,0,8,12">
                <TextBlock Text="Notifications"
                          Foreground="#AAFFFFFF"
                          FontSize="14"
                          FontWeight="SemiBold"
                          VerticalAlignment="Center"/>
                <Button Content="Clear All"
                       Background="Transparent"
                       Foreground="#007AFF"
                       BorderThickness="0"
                       FontSize="14"
                       HorizontalAlignment="Right"
                       Click="ClearAllNotifications_Click"
                       Cursor="Hand"/>
            </Grid>

            <!-- Notifications List or Empty State -->
            <ScrollViewer Grid.Row="3"
                         VerticalScrollBarVisibility="Hidden"
                         HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- Notification Cards -->
                    <ItemsControl x:Name="NotificationsList"
                                 ItemsSource="{Binding Notifications}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                       CornerRadius="16"
                                       Padding="14,12">
                                    <Border.Background>
                                        <SolidColorBrush Color="#2C2C2E" Opacity="0.95"/>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- App Icon -->
                                        <Border Grid.Column="0"
                                               CornerRadius="10"
                                               Width="40" Height="40"
                                               Margin="0,0,12,0"
                                               VerticalAlignment="Top"
                                               ClipToBounds="True">
                                            <Border.Background>
                                                <SolidColorBrush Color="#FFFFFF" Opacity="0.1"/>
                                            </Border.Background>
                                            <Image Source="{Binding AppIcon}"
                                                   Width="28" Height="28"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Content -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                            <Grid>
                                                <TextBlock Text="{Binding AppName}"
                                                          Foreground="#99FFFFFF"
                                                          FontSize="12"/>
                                                <TextBlock Text="{Binding TimeAgo}"
                                                          Foreground="#66FFFFFF"
                                                          FontSize="11"
                                                          HorizontalAlignment="Right"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Title}"
                                                      Foreground="White"
                                                      FontSize="14"
                                                      FontWeight="SemiBold"
                                                      Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Content}"
                                                      Foreground="#BBFFFFFF"
                                                      FontSize="13"
                                                      TextWrapping="Wrap"
                                                      MaxHeight="52"
                                                      TextTrimming="CharacterEllipsis"
                                                      Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Dismiss -->
                                        <Button Grid.Column="2"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Width="28" Height="28"
                                               VerticalAlignment="Top"
                                               Click="DismissNotification_Click"
                                               Tag="{Binding}"
                                               Cursor="Hand"
                                               Margin="4,0,0,0">
                                            <Path Data="M6,6 L18,18 M6,18 L18,6"
                                                 Stroke="#55FFFFFF"
                                                 StrokeThickness="1.5"
                                                 Stretch="Uniform"
                                                 Width="10" Height="10"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty State -->
                    <StackPanel x:Name="EmptyState"
                               Visibility="{Binding HasNotifications, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                               HorizontalAlignment="Center"
                               Margin="0,60,0,0">
                        <Border Background="#20FFFFFF"
                               CornerRadius="28"
                               Width="56" Height="56"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16">
                            <Path Data="M12,22c1.1,0,2-0.9,2-2h-4C10,21.1,10.9,22,12,22z M18,16v-5c0-3.07-1.63-5.64-4.5-6.32V4c0-0.83-0.67-1.5-1.5-1.5 S10.5,3.17,10.5,4v0.68C7.64,5.36,6,7.92,6,11v5l-2,2v1h16v-1L18,16z"
                                 Fill="#88FFFFFF" Stretch="Uniform"
                                 Width="26" Height="26"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="No Notifications"
                                  Foreground="#88FFFFFF"
                                  FontSize="17"
                                  FontWeight="SemiBold"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="You're all caught up"
                                  Foreground="#55FFFFFF"
                                  FontSize="13"
                                  HorizontalAlignment="Center"
                                  Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Bottom Home Indicator -->
        <Border Background="#50FFFFFF"
               CornerRadius="2.5"
               Width="134" Height="5"
               VerticalAlignment="Bottom"
               HorizontalAlignment="Center"
               Margin="0,0,0,12"/>
    </Grid>
</UserControl>
