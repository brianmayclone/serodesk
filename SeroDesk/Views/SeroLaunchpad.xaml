<UserControl x:Class="SeroDesk.Views.SeroLaunchpad"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SeroDesk.Views"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1920">
    
    <UserControl.Resources>
        <!-- Resources no longer needed - using Canvas-based SeroIconView -->
    </UserControl.Resources>
    
    <!-- Full-Screen iOS-Style App Grid -->
    <Grid x:Name="LaunchpadGrid"
          ManipulationStarting="LaunchpadGrid_ManipulationStarting"
          ManipulationDelta="LaunchpadGrid_ManipulationDelta"
          ManipulationCompleted="LaunchpadGrid_ManipulationCompleted"
          IsManipulationEnabled="True">
        
        <!-- Windows Wallpaper Background -->
        <Rectangle x:Name="WallpaperBackground" 
                  Fill="{Binding CurrentWallpaper}"
                  Stretch="UniformToFill"/>
        
        <!-- Subtle Dark Overlay for better readability -->
        <Rectangle Fill="Black" Opacity="0.1"/>
        
        <!-- Status Bar moved to separate StatusBarWindow -->
        
        <!-- Canvas-based Icon System -->
        <Grid Margin="80,110,80,100">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Page Indicators (iOS-style dots) -->
            <Border Grid.Row="0"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,20"
                    Background="#30000000"
                    CornerRadius="12"
                    Padding="8,4">
                <StackPanel Orientation="Horizontal"
                           HorizontalAlignment="Center"
                           x:Name="PageIndicators">
                    <!-- Page dots will be added dynamically -->
                </StackPanel>
            </Border>
            
            <!-- Main Canvas for Icons -->
            <Border Grid.Row="1" ClipToBounds="True">
                <Canvas x:Name="IconCanvas" 
                       Background="Transparent"
                       ManipulationStarting="IconCanvas_ManipulationStarting"
                       ManipulationDelta="IconCanvas_ManipulationDelta"
                       ManipulationCompleted="IconCanvas_ManipulationCompleted"
                       IsManipulationEnabled="True">
                    <!-- Icons will be added dynamically as SeroIconView controls -->
                </Canvas>
            </Border>
            
            <!-- Drop Zone Indicators (will be added dynamically during drag) -->
            <Canvas x:Name="DropZoneCanvas" 
                    Grid.Row="1"
                    Background="Transparent"
                    IsHitTestVisible="False">
                <!-- Drop zone indicators will be added here during drag operations -->
            </Canvas>
        </Grid>
        
        <!-- Done Button (visible in edit mode) -->
        <Button x:Name="DoneButton"
                Content="Done"
                Visibility="Collapsed"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="0,44,24,0"
                Cursor="Hand"
                Click="DoneButton_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="#CC007AFF"
                            CornerRadius="16"
                            Padding="20,8">
                        <TextBlock Text="{TemplateBinding Content}"
                                  Foreground="White"
                                  FontSize="15"
                                  FontWeight="SemiBold"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Search Bar (iOS Spotlight-style with glassmorphism) -->
        <Border x:Name="SearchBar"
                CornerRadius="16"
                Width="480" Height="44"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,44,0,0"
                BorderThickness="1"
                Visibility="Visible">
            <Border.Background>
                <SolidColorBrush Color="#000000" Opacity="0.35"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.2"/>
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.25" ShadowDepth="4"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Search Icon -->
                <Path Grid.Column="0"
                      Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                      Fill="#AAFFFFFF"
                      Stretch="Uniform"
                      Width="18" Height="18"
                      Margin="14,0,8,0"/>

                <!-- Search TextBox -->
                <TextBox Grid.Column="1"
                        x:Name="SearchBox"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="Normal"
                        VerticalAlignment="Center"
                        Margin="0,0,16,0"
                        CaretBrush="White"
                        AutomationProperties.Name="Search applications"
                        AutomationProperties.HelpText="Type to search for installed applications"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        TextChanged="SearchBox_TextChanged">
                    <TextBox.Resources>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <ScrollViewer x:Name="PART_ContentHost"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- Placeholder Text -->
                <TextBlock Grid.Column="1"
                          Text="Search"
                          Foreground="#80FFFFFF"
                          FontSize="15"
                          VerticalAlignment="Center"
                          Margin="0,0,16,0"
                          IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text.Length, ElementName=SearchBox}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>
        
        <!-- Group Creation Overlay -->
        <Grid x:Name="GroupCreationOverlay"
              Background="#80000000"
              Visibility="Collapsed"
              MouseLeftButtonDown="CancelGroupCreation_Click">
            <Border Background="#CC1E1E1E"
                    CornerRadius="20"
                    Width="400"
                    Height="200"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Margin="40">
                    <TextBlock Text="Create New Group"
                              Foreground="White"
                              FontSize="18"
                              FontWeight="Bold"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,20"/>
                    
                    <Border Background="#40FFFFFF"
                            BorderThickness="1"
                            BorderBrush="#60FFFFFF"
                            CornerRadius="8"
                            Margin="0,0,0,20">
                        <TextBox x:Name="GroupNameTextBox"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="12"
                                FontSize="14"
                                Text="New Group"/>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal"
                               HorizontalAlignment="Center">
                        <Button Content="Cancel"
                               Foreground="White"
                               BorderThickness="0"
                               Padding="20,8"
                               Margin="0,0,10,0"
                               Click="CancelGroupCreation_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#40FFFFFF"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button Content="Create"
                               Background="Transparent"
                               Foreground="White"
                               BorderThickness="0"
                               Padding="20,8"
                               Click="CreateGroup_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#007AFF"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Group Expanded View Overlay (iOS Folder Style) -->
        <Grid x:Name="GroupExpandedOverlay"
              Background="#90000000"
              Visibility="Collapsed"
              MouseLeftButtonDown="GroupExpandedOverlay_MouseDown">
            <Border CornerRadius="24"
                    MaxWidth="520"
                    MaxHeight="460"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="40">
                <Border.Background>
                    <SolidColorBrush Color="#1C1C1E" Opacity="0.92"/>
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#FFFFFF" Opacity="0.12"/>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.5" ShadowDepth="8"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Group Header with editable name -->
                    <TextBlock x:Name="GroupExpandedTitle"
                              Text="Group Name"
                              Foreground="White"
                              FontSize="22"
                              FontWeight="SemiBold"
                              HorizontalAlignment="Center"
                              Margin="24,24,24,16"/>

                    <!-- Group Apps Grid -->
                    <ScrollViewer Grid.Row="1"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 Margin="16,0,16,20">
                        <ItemsControl x:Name="GroupAppsGrid">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="90" Height="100"
                                            Margin="6"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="GroupAppIcon_Click"
                                            Tag="{Binding}"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Grid>
                                                    <!-- Icon -->
                                                    <Border CornerRadius="16"
                                                           Width="56" Height="56"
                                                           VerticalAlignment="Top"
                                                           HorizontalAlignment="Center"
                                                           ClipToBounds="True">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="6" Opacity="0.25" ShadowDepth="2"/>
                                                        </Border.Effect>
                                                        <Image Source="{Binding IconImage}"
                                                               Width="56" Height="56"
                                                               Stretch="Uniform"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Border>

                                                    <!-- App Name -->
                                                    <TextBlock Text="{Binding Name}"
                                                             Foreground="#DDFFFFFF"
                                                             FontSize="10"
                                                             TextAlignment="Center"
                                                             TextWrapping="NoWrap"
                                                             TextTrimming="CharacterEllipsis"
                                                             VerticalAlignment="Bottom"
                                                             HorizontalAlignment="Center"
                                                             MaxWidth="84"
                                                             Margin="0,0,0,6"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Group Rename Overlay -->
        <Grid x:Name="GroupRenameOverlay"
              Background="#80000000"
              Visibility="Collapsed"
              MouseLeftButtonDown="CancelGroupRename_Click">
            <Border Background="#CC1E1E1E"
                    CornerRadius="20"
                    Width="400"
                    Height="200"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Margin="40">
                    <TextBlock Text="Rename Group"
                              Foreground="White"
                              FontSize="18"
                              FontWeight="Bold"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,20"/>
                    
                    <Border Background="#40FFFFFF"
                            BorderThickness="1"
                            BorderBrush="#60FFFFFF"
                            CornerRadius="8"
                            Margin="0,0,0,20">
                        <TextBox x:Name="GroupRenameTextBox"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="12"
                                FontSize="14"
                                Text=""/>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal"
                               HorizontalAlignment="Center">
                        <Button Content="Cancel"
                               Background="Transparent"
                               Foreground="White"
                               BorderThickness="0"
                               Padding="20,8"
                               Margin="0,0,10,0"
                               Click="CancelGroupRename_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#40FFFFFF"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button Content="Rename"
                               Background="Transparent"
                               Foreground="White"
                               BorderThickness="0"
                               Padding="20,8"
                               Click="ConfirmGroupRename_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#007AFF"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>