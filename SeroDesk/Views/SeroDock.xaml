<UserControl x:Class="SeroDesk.Views.SeroDock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:effects="clr-namespace:SeroDesk.Effects"
             mc:Ignorable="d"
             Height="94"
             d:DesignWidth="1920">

    <Grid>
        <!-- Dock Container -->
        <Grid VerticalAlignment="Bottom" Margin="0,0,0,10">

            <!-- Dock Background - polished glassmorphism pill -->
            <Border x:Name="DockBackground"
                    Height="76"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    CornerRadius="28"
                    MinWidth="380"
                    Padding="16,10"
                    ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect Color="#52000000" BlurRadius="24" ShadowDepth="6" Opacity="0.22"/>
                </Border.Effect>

                <Grid>
                    <Rectangle x:Name="DockBackdropMaterial"
                               RadiusX="28"
                               RadiusY="28"
                               Stretch="Fill">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#D8F7F9FC" Offset="0"/>
                                <GradientStop Color="#C7E8EDF5" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                        <Rectangle.Effect>
                            <effects:LiquidGlassShaderEffect Distortion="0.34"
                                                             EdgeIntensity="0.28"
                                                             GlowAmount="0.44"
                                                             SaturationBoost="0.18"/>
                        </Rectangle.Effect>
                    </Rectangle>

                    <Border CornerRadius="28" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#B2FFFFFF" Offset="0"/>
                                <GradientStop Color="#80FFFFFF" Offset="0.18"/>
                                <GradientStop Color="#56F6F8FB" Offset="0.56"/>
                                <GradientStop Color="#64E8ECF3" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#9EFFFFFF" Offset="0"/>
                                <GradientStop Color="#56FFFFFF" Offset="0.3"/>
                                <GradientStop Color="#24FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                    </Border>

                    <Border CornerRadius="28"
                            Margin="1"
                            Background="#10FFFFFF"/>

                    <Border Height="22"
                            CornerRadius="18"
                            VerticalAlignment="Top"
                            Margin="18,5,18,0"
                            Opacity="0.72"
                            IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#E8FFFFFF" Offset="0"/>
                                <GradientStop Color="#6CFFFFFF" Offset="0.55"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Border Height="1"
                            VerticalAlignment="Bottom"
                            Margin="22,0,22,8"
                            Opacity="0.16"
                            IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00FFFFFF" Offset="0"/>
                                <GradientStop Color="#AFFFFFFF" Offset="0.5"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Dock Items -->
                    <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- Home -->
                        <ColumnDefinition Width="Auto"/> <!-- Separator -->
                        <ColumnDefinition Width="Auto"/> <!-- Running Apps -->
                        <ColumnDefinition Width="Auto"/> <!-- Separator -->
                        <ColumnDefinition Width="Auto"/> <!-- Explorer -->
                        <ColumnDefinition Width="Auto"/> <!-- Settings -->
                        <ColumnDefinition Width="Auto"/> <!-- Trash -->
                    </Grid.ColumnDefinitions>

                    <!-- Home Button -->
                    <Button Grid.Column="0"
                            x:Name="HomeButton"
                            Width="52" Height="52"
                            Margin="4,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="HomeButton_Click"
                            ToolTip="Home"
                            AutomationProperties.Name="Home"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid RenderTransformOrigin="0.5,1.0">
                                    <Grid.RenderTransform>
                                        <ScaleTransform x:Name="HomeScale" ScaleX="1" ScaleY="1"/>
                                    </Grid.RenderTransform>
                                    <Border CornerRadius="18"
                                            Background="#14FFFFFF"
                                            BorderBrush="#2CFFFFFF"
                                            BorderThickness="0.6"
                                            Width="52"
                                            Height="52">
                                        <Path Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z"
                                              Fill="White" Stretch="Uniform"
                                              Width="22" Height="22"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HomeScale" Storyboard.TargetProperty="ScaleX" To="1.14" Duration="0:0:0.14"/>
                                                    <DoubleAnimation Storyboard.TargetName="HomeScale" Storyboard.TargetProperty="ScaleY" To="1.14" Duration="0:0:0.14"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="HomeScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.18"/>
                                                    <DoubleAnimation Storyboard.TargetName="HomeScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.18"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Separator -->
                    <Border Grid.Column="1" Width="1" Height="30" Margin="8,0"
                            VerticalAlignment="Center" Opacity="0.12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00FFFFFF" Offset="0"/>
                                <GradientStop Color="#CCFFFFFF" Offset="0.5"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Running Apps -->
                    <ItemsControl Grid.Column="2"
                                x:Name="RunningAppsControl"
                                ItemsSource="{Binding RunningApplications}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="52" Height="52"
                                        Margin="3,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="DockIcon_Click"
                                        MouseEnter="DockIcon_MouseEnter"
                                        MouseLeave="DockIcon_MouseLeave"
                                        MouseRightButtonUp="DockIcon_RightClick"
                                        Tag="{Binding}"
                                        Cursor="Hand">
                                    <Button.ToolTip>
                                        <ToolTip Placement="Top" VerticalOffset="-8" HasDropShadow="True">
                                            <ToolTip.Template>
                                                <ControlTemplate TargetType="ToolTip">
                                                    <Border Background="#E6202020" CornerRadius="8" Padding="12,6">
                                                        <TextBlock Text="{Binding Title}" Foreground="White" FontSize="12"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </ToolTip.Template>
                                        </ToolTip>
                                    </Button.ToolTip>
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Open" Click="ContextMenu_Open"/>
                                            <MenuItem Header="Close Window" Click="ContextMenu_Close"/>
                                            <Separator/>
                                            <MenuItem Header="Unpin from Dock" Click="ContextMenu_UnpinFromDock"/>
                                            <Separator/>
                                            <MenuItem Header="Open File Location" Click="ContextMenu_OpenFileLocation"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid RenderTransformOrigin="0.5,1.0">
                                                <Grid.RenderTransform>
                                                    <ScaleTransform x:Name="IconScale" ScaleX="1" ScaleY="1"/>
                                                </Grid.RenderTransform>
                                                <Border CornerRadius="18" ClipToBounds="True">
                                                    <Image Source="{Binding Icon, Converter={StaticResource IconToImageSourceConverter}}"
                                                           Width="46" Height="46"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Border>
                                                <Border Width="16" Height="4"
                                                        Background="#EEFFFFFF"
                                                        CornerRadius="2"
                                                        VerticalAlignment="Bottom"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,0,0,-6"
                                                        Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX"
                                                                               To="1.28" Duration="0:0:0.15">
                                                                    <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.28"/></DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                                <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY"
                                                                               To="1.28" Duration="0:0:0.15">
                                                                    <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.28"/></DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX"
                                                                               To="1.0" Duration="0:0:0.2">
                                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                                <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY"
                                                                               To="1.0" Duration="0:0:0.2">
                                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Separator -->
                    <Border Grid.Column="3" Width="1" Height="30" Margin="8,0"
                            VerticalAlignment="Center" Opacity="0.12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00FFFFFF" Offset="0"/>
                                <GradientStop Color="#CCFFFFFF" Offset="0.5"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Explorer -->
                    <Button Grid.Column="4" Width="52" Height="52" Margin="3,0"
                            Background="Transparent" BorderThickness="0"
                            Click="FinderIcon_Click" ToolTip="Files" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid RenderTransformOrigin="0.5,1.0">
                                    <Grid.RenderTransform>
                                        <ScaleTransform x:Name="ExScale" ScaleX="1" ScaleY="1"/>
                                    </Grid.RenderTransform>
                                    <Border CornerRadius="18" ClipToBounds="True">
                                        <Image x:Name="ExplorerIcon" Width="46" Height="46"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard><Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ExScale" Storyboard.TargetProperty="ScaleX" To="1.24" Duration="0:0:0.14"/>
                                                <DoubleAnimation Storyboard.TargetName="ExScale" Storyboard.TargetProperty="ScaleY" To="1.24" Duration="0:0:0.14"/>
                                            </Storyboard></BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard><Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ExScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="ExScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.15"/>
                                            </Storyboard></BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Settings -->
                    <Button Grid.Column="5" x:Name="SettingsButton"
                            Width="52" Height="52" Margin="3,0"
                            Background="Transparent" BorderThickness="0"
                            Click="SettingsButton_Click" ToolTip="Settings" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid RenderTransformOrigin="0.5,1.0">
                                    <Grid.RenderTransform>
                                        <ScaleTransform x:Name="SetScale" ScaleX="1" ScaleY="1"/>
                                    </Grid.RenderTransform>
                                    <Border CornerRadius="18"
                                            Background="#14FFFFFF"
                                            BorderBrush="#2CFFFFFF"
                                            BorderThickness="0.6"
                                            Width="52"
                                            Height="52">
                                        <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                              Fill="White" Stretch="Uniform"
                                              Width="22" Height="22"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard><Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="SetScale" Storyboard.TargetProperty="ScaleX" To="1.14" Duration="0:0:0.14"/>
                                                <DoubleAnimation Storyboard.TargetName="SetScale" Storyboard.TargetProperty="ScaleY" To="1.14" Duration="0:0:0.14"/>
                                            </Storyboard></BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard><Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="SetScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="SetScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.15"/>
                                            </Storyboard></BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Recycle Bin -->
                    <Button Grid.Column="6" Width="52" Height="52" Margin="3,0"
                            Background="Transparent" BorderThickness="0"
                            Click="TrashIcon_Click" ToolTip="Recycle Bin" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid RenderTransformOrigin="0.5,1.0">
                                    <Grid.RenderTransform>
                                        <ScaleTransform x:Name="TrashScale" ScaleX="1" ScaleY="1"/>
                                    </Grid.RenderTransform>
                                    <Border CornerRadius="18" ClipToBounds="True">
                                        <Image x:Name="RecycleBinIcon" Width="46" Height="46"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard><Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="TrashScale" Storyboard.TargetProperty="ScaleX" To="1.24" Duration="0:0:0.14"/>
                                                <DoubleAnimation Storyboard.TargetName="TrashScale" Storyboard.TargetProperty="ScaleY" To="1.24" Duration="0:0:0.14"/>
                                            </Storyboard></BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard><Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="TrashScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="TrashScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.15"/>
                                            </Storyboard></BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Hidden state indicator line -->
        <Border x:Name="DockIndicator"
                Width="54" Height="6"
                Background="#50FFFFFF"
                CornerRadius="3"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,8"
                Visibility="Collapsed"/>
    </Grid>
</UserControl>
